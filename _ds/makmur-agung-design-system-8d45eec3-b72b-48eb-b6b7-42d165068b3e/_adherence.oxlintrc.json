{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/storefront/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Saira|Saira Condensed|Saira Semi Condensed))/i]",
        "message": "Font not provided by the design system. Available: Saira, Saira Condensed, Saira Semi Condensed."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--amber",
      "--aozoom-amber",
      "--aozoom-orange",
      "--aozoom-orange-deep",
      "--beam-blue",
      "--beam-cyan",
      "--beam-glow",
      "--beam-gradient",
      "--beam-white",
      "--body",
      "--body-md",
      "--body-md-lh",
      "--body-sm",
      "--body-sm-lh",
      "--body-strong",
      "--canvas",
      "--caption",
      "--caption-lh",
      "--caption-track",
      "--danger",
      "--display-lg",
      "--display-lg-lh",
      "--display-md",
      "--display-md-lh",
      "--display-sm",
      "--display-sm-lh",
      "--display-xl",
      "--display-xl-lh",
      "--font-body",
      "--font-display",
      "--font-mono",
      "--hairline",
      "--hairline-strong",
      "--ignite-glow",
      "--ignite-gradient",
      "--label",
